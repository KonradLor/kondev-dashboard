# ============================================================================
# kondev Dashboard - environment template
# ============================================================================
# Copy to `.env` and fill in real values. NEVER commit `.env` (it holds secrets).
#   cp .env.example .env
# ============================================================================

# --- Built-in admin login (fallback, optional) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# --- OIDC (Authentik) - central single sign-on ---
OIDC_CLIENT_ID=your-oidc-client-id
OIDC_CLIENT_SECRET=your-oidc-client-secret
OIDC_AUTHORIZE_URL=https://auth.example.com/application/o/authorize/
OIDC_TOKEN_URL=https://auth.example.com/application/o/token/
OIDC_USERINFO_URL=https://auth.example.com/application/o/userinfo/
OIDC_REDIRECT_URI=https://example.com/auth/callback
OIDC_ADMIN_GROUP=authentik Admins
OIDC_POST_LOGOUT_URL=https://example.com/

# --- Authentik API (user management) ---
AUTHENTIK_API_URL=http://authentik-server:9000
AUTHENTIK_PUBLIC_HOST=auth.example.com
AUTHENTIK_API_TOKEN=your-authentik-api-token
AUTHENTIK_RECOVERY_EMAIL_STAGE=stage-uuid-for-recovery-email
AUTHENTIK_ENROLL_EMAIL_STAGE=stage-uuid-for-enroll-email
AUTHENTIK_USERS_GROUP=users

# --- Internal service-to-service token (must match other services' .env) ---
INTERNAL_API_TOKEN=generate-a-long-random-string
VAULT_INTERNAL_URL=http://konradvault-backend:8000
VOICE_INTERNAL_URL=http://voice-app:8000
